{
  "name": "obsidian-browser",
  "version": "1.0.2",
  "description": "A clean, dark Electron browser with persistent sessions",
  "main": "electron/main.js",
  "author": "Obsidian Team",
  "scripts": {
    "dev": "cross-env NODE_ENV=development concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "vite build",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "build:win": "npm run build:renderer && electron-builder --win",
    "publish:win": "npm run build:renderer && electron-builder --win -p always",
    "build:linux": "npm run build:renderer && electron-builder --linux",
    "build": "npm run build:renderer && electron-builder",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.obsidian.browser",
    "productName": "Obsidian",
    "directories": {
      "buildResources": "assets",
      "output": "dist-electron"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "avict1809",
        "repo": "obsidian-browser"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "Obsidian-Mac-${arch}-${version}.${ext}",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "hardenedRuntime": true
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Obsidian-Windows-${version}.${ext}",
      "sign": null,
      "verifyUpdateCodeSignature": false
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network;WebBrowser"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "crypto": "^1.0.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "fs": "^0.0.1-security",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "cross-env": "^10.1.0",
    "electron": "^41.0.0",
    "electron-builder": "^24.0.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  }
}
